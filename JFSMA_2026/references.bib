  title     = {Neuro-Symbolic World Models for Adapting to Open World Novelty},
  year      = {2023},
  isbn      = {9781450394321},
  publisher = {Int. Foundation for Autonomous Agents and Multiagent Systems},
  address   = {Richland, SC},
  abstract  = {Most reinforcement learning methods assume that the world is a closed, fixed process, when in reality most real world problems are open, changing over time. To address this, we introduce WorldCloner, an end-to-end trainable neuro-symbolic world model that learns an efficient symbolic model of transitions and uses this world model to improve novelty adaptation. We show that the symbolic world model helps WorldCloner adapt its policy more efficiently than neural-only reinforcement learning methods.},
  booktitle = {Proc. of the Int. Conf. on Autonomous Agents and Multiagent Systems},
  pages     = {2848--2850},
  numpages  = {3},
  keywords  = {neuro-symbolic, open world learning, reinforcement learning},
  location  = {London, United Kingdom}
}

